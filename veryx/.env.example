# ─────────────────────────────────────────────────────────────
# VERYX AI-OS — Environment configuration
# Copy to `.env` and adjust. Sensible local defaults are provided.
# ─────────────────────────────────────────────────────────────

# Database.
# Local dev uses SQLite (zero-config). For production set this to a
# PostgreSQL URL and change `provider` in prisma/schema.prisma to "postgresql".
DATABASE_URL="file:./dev.db"

# Auth — JWT signing secret (HS256). CHANGE THIS in production.
VERYX_JWT_SECRET="dev-veryx-jwt-secret-change-me-please-32min"
# Access token lifetime (minutes) and refresh token lifetime (days) — Blueprint §6.2.
VERYX_ACCESS_TOKEN_MINUTES=15
VERYX_REFRESH_TOKEN_DAYS=30

# BitriPay gateway (Blueprint §7). Sandbox simulated by default — no real calls.
BITRIPAY_MODE="sandbox"
BITRIPAY_API_KEY="vx_sandbox_bitripay_key"
BITRIPAY_WEBHOOK_SECRET="vx_sandbox_webhook_secret_rotate_me"

# Optional: LLM provider keys for live agent reasoning (Blueprint §8.4).
# When unset, the agent engine runs in deterministic simulation mode.
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# Public base URL.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
