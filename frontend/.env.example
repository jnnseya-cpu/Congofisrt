# ============================================================
# CDP-AI OS — Environment Variables Example
# Copy this file to .env.local and fill in your values
# ============================================================

# Database
DATABASE_URL=postgresql://cdp_user:cdp_password@localhost:5432/cdp_ai_os
POSTGRES_DB=cdp_ai_os
POSTGRES_USER=cdp_user
POSTGRES_PASSWORD=cdp_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# NextAuth
NEXTAUTH_SECRET=your-secret-key-here-change-in-production
NEXTAUTH_URL=http://localhost:3000

# Anthropic AI
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-6

# Backend API
NEXT_PUBLIC_API_URL=http://localhost:8000
BACKEND_SECRET_KEY=your-backend-secret-key

# App Config
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=CDP-AI OS
NEXT_PUBLIC_APP_VERSION=1.0.0

# Optional: Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
